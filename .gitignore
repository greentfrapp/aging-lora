# Agent JSONL logs — voluminous, regenerated on re-runs.
.research/logs/
# Research-agent internal state — ephemeral, regenerated on each run.
.research/state.json
.research/lock

# Claude Code per-user session state (scheduled tasks, local settings).
.claude/

# Top-level run logs (e.g. harmonize_v3.log) — reproducible from scripts.
logs/

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# Node
node_modules/

# Raw downloaded cohort data — large (~45 GB). Reproducible via:
#   scripts/download_terekhova.py, src/data/download_cohorts.py, direct CellxGene URLs
data/cohorts/raw/

# Harmonized per-cell-type AnnData — regenerated by src/data/harmonize_cohorts.py
data/cohorts/integrated/

# AIDA evaluation-only harmonized h5ads — regenerated by src/data/harmonize_aida.py
data/cohorts/aida_eval/

# Download + run logs
data/cohorts/logs/

# Vendored sc-ImmuAging reference repo (cloned from GitHub; contains its own .git)
# Re-clone via: git clone https://github.com/CiiM-Bioinformatics-group/scImmuAging data/scImmuAging
data/scImmuAging/

# Vendored scAgeClock repo + 44 MB GMA checkpoint.
# Re-clone via: git clone --depth=1 https://github.com/gangcai/scageclock data/scAgeClock/scageclock
data/scAgeClock/

# Pasta pseudobulk TSVs (~597 MB) — regenerable in ~3 min via
#   uv run python src/baselines/pseudobulk_for_pasta.py
# We commit the *_meta.csv files (small) but not the gene × donor TSVs.
results/baselines/pasta_pseudobulk/*.tsv

# Foundation-model checkpoints — large (~5 GB total). Re-download via:
#   uv run python scripts/download_foundation_models.py
save/

# Note: data/cohort_summary.csv was previously gitignored as "transient" during
# the Stephenson-only sanity-run era. Now that 3-cohort harmonization is frozen,
# we commit it as a small reproducibility artefact alongside loco_folds.json.

# Local audit scratchpad — third-party paper supplementaries and one-off
# inspection scripts. Reproducible via the URLs documented in
# methods/leakage_audit_notes.md; do not commit (copyright + bloat).
scratchpad/
