# Agent JSONL logs — voluminous, regenerated on re-runs.
.research/logs/

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# Node
node_modules/

# Raw downloaded cohort data — large (~45 GB). Reproducible via:
#   scripts/download_terekhova.py, src/data/download_cohorts.py, direct CellxGene URLs
data/cohorts/raw/

# Harmonized per-cell-type AnnData — regenerated by src/data/harmonize_cohorts.py
data/cohorts/integrated/

# Download + run logs
data/cohorts/logs/

# Vendored sc-ImmuAging reference repo (cloned from GitHub; contains its own .git)
# Re-clone via: git clone https://github.com/CiiM-Bioinformatics-group/scImmuAging data/scImmuAging
data/scImmuAging/

# Foundation-model checkpoints — large (~5 GB total). Re-download via:
#   uv run python scripts/download_foundation_models.py
save/

# Transient run artefacts (regenerated each run)
data/cohort_summary.csv

# Local audit scratchpad — third-party paper supplementaries and one-off
